# React SPA routing on Apache / cPanel.
# Any request that isn't a real file or directory is rewritten to index.html
# so React Router can handle the URL on the client. Without this, deep links
# like /listings 404 on hard refresh.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS (uncomment if cPanel SSL is active and you want all traffic over TLS)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Don't rewrite real files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else → index.html (SPA fallback)
    RewriteRule ^ index.html [L]
</IfModule>

# Sensible cache headers for hashed asset files
<IfModule mod_headers.c>
    <FilesMatch "\.(?:js|css|svg|woff2?|ttf|eot|png|jpg|jpeg|gif|webp|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # index.html should always revalidate so users pick up new builds
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Gzip / brotli compression where supported
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
